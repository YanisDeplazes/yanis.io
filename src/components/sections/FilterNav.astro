---
interface Props {
  categories: string[];
  pluralMapping: Record<string, string>;
}

const { categories, pluralMapping } = Astro.props;
---

<nav class="filter-nav">
  <div class="nav-inner">
    <span class="filter-btn active font-spacing-small" data-filter="all"
      >all</span
    >
    {
      categories.map((cat) => (
        <span class="filter-btn font-spacing-small" data-filter={cat}>
          {pluralMapping[cat] || cat + 's'}
        </span>
      ))
    }
  </div>
</nav>

<style lang="scss">
  .filter-nav {
    margin-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(255, 62, 0, 0.15);

    .nav-inner {
      margin-bottom: 3px;

      padding: 0 var(--space-xs);
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-l);
    }

    .filter-btn {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.2s ease;
      position: relative;

      &:hover {
        opacity: 0.7;
      }

      &.active {
        opacity: 1;
        font-weight: 600;
        &::after {
          content: '';
          position: absolute;
          bottom: -4px;
          left: 0;
          width: 100%;
          height: 1px;
          background: currentColor;
        }
      }
    }
  }
</style>
