---
import Wrapper from '../../layouts/Wrapper.astro';
import Info from './Info.astro';

interface Props {
  title: string;
  start?: Date;
  end?: Date;
  ongoing?: boolean;
  type?: string;
}

const { title, start, end, ongoing, type } = Astro.props;
---

<section class="project-title">
  <Wrapper>
    <div class="container">
      <div class="title-container">
        <Info start={start} end={end} ongoing={ongoing} type={type} />
        <h1 class="title title-font-bold font-size-3" set:html={title} />
        <slot name="additional" />
      </div>

      <div class="content">
        <slot name="details" />
      </div>
    </div>
  </Wrapper>
</section>

<style lang="scss" is:global>
  // Your existing styles remain the same
  .project-title {
    padding-top: 0;
    padding-bottom: 0;

    .container {
      position: relative;
      padding-bottom: var(--space-s);
      @media (min-width: 1000px) {
        display: flex;
        justify-items: center; // Note: you might want align-items: flex-start or center
        gap: var(--space-3xl);
        row-gap: var(--space-s);
      }

      &::after {
        content: '';
        background-color: var(--color-accent);
        height: 1px;
        width: 100%;
        position: absolute;
        bottom: 0;
        left: 0;
        opacity: 0.5;
      }

      .title-container,
      .content {
        width: 100%;
        color: var(--color-accent);

        .title {
          margin-block-start: var(--space-3xs);
          margin-bottom: var(--space-xs); // Added some breathing room
        }
      }
      .title-container {
        @media (min-width: 1000px) {
          width: 68%;
        }
      }
      .content {
        @media (min-width: 1000px) {
          width: 32%;
        }
      }

      .content .info {
        margin-block-end: 10px;
      }

      a {
        text-decoration: underline;
        transition: all 0.2s ease-in-out;
        font-weight: bold;
        &:hover {
          opacity: 0.8;
        }
      }
    }
  }
</style>
