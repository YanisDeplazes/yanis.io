---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/sections/Gallery.astro';
import Lightbox from '../../components/sections/Lightbox.astro';
import Description from '../../components/sections/Description.astro';
import List from '../../components/sections/List.astro';

// TypeScript Interface
interface ProjectData {
  title: string;
  description: string;
  start: Date;
  end?: Date;
  type: string[];
  thumbnail: string;
  selected: boolean;
  ongoing: boolean;
  gallery?: {
    content?: { imageUrl?: string; alt?: string; videoUrl?: string }[];
  };
  lists?: {
    title: string;
    items: string[];
  }[];
}

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{jpg,jpeg,png,webp}',
);
const resolveImage = async (url: string) => images[`/src/assets${url}`]?.();

const { slug } = Astro.params;
const loadProject = await getEntry('work', slug!);

if (!loadProject) {
  throw new Error(`Project not found: ${slug}`);
}

// Destructure lists here
const {
  title,
  description,
  thumbnail,
  end,
  type,
  ongoing,
  start,
  gallery,
  lists,
  location,
  context,
} = loadProject.data;

const resolvedThumbnail: ImageMetadata | undefined = thumbnail
  ? (await resolveImage(thumbnail))?.default
  : undefined;

const suffix = 'Yanis Deplazes';
const { Content } = await loadProject.render();

const yearStart = start ? new Date(start).getFullYear() : undefined;
const yearEnd = end ? new Date(end).getFullYear() : undefined;

// Logic to determine if we have enough date info to show anything
const hasDate = yearStart || yearEnd;

const date = hasDate
  ? ongoing
    ? `since ${yearStart}`
    : yearEnd === yearStart
      ? `${yearEnd}`
      : yearEnd
        ? `${yearStart} — ${yearEnd}`
        : `${yearStart}`
  : null;

export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map((project) => ({
    params: { slug: project.slug },
  }));
}
---

<Layout
  title={`${title} — ${suffix}`}
  description={description}
  imageSrc={resolvedThumbnail?.src ?? '/assets/images/default.png'}
>
  <Description title={title}>
    <div slot="details">
      {
        location && (
          <List title="Location">
            <li>{Array.isArray(location) ? location.join(' | ') : location}</li>
          </List>
        )
      }

      {
        context && (
          <List title="Context">
            <li>{context}</li>
          </List>
        )
      }

      {
        type && (
          <List title="Type">
            <li>
              {/* Check if it's an array before joining, otherwise just render it */}
              {Array.isArray(type) ? type.join(', ') : type}
            </li>
          </List>
        )
      }

      {
        date && (
          <List title="Year">
            <li>{date}</li>
          </List>
        )
      }

      {
        lists?.map((list) => (
          <List title={list.title}>
            {list.items.map((itemHtml) => (
              <li set:html={itemHtml} />
            ))}
          </List>
        ))
      }
    </div>

    <div slot="additional">
      <Content components={{ List }} />
    </div>
  </Description>

  {gallery && <Gallery galleryData={gallery.content} />}
  <Lightbox galleryData={gallery?.content} />
</Layout>

<script>
  const updateScrollColor = () => {
    const scrollThreshold = 100;
    const body = document.body;
    const defaultColor = 'var(--color-background)';

    if (window.scrollY >= scrollThreshold) {
      body.style.setProperty(
        '--color-project',
        'var(--color-background-light)',
      );
    } else {
      body.style.setProperty('--color-project', defaultColor);
    }
  };

  // Listen for scroll
  window.addEventListener('scroll', updateScrollColor);

  // Initialize on load to check current scroll position
  window.addEventListener('DOMContentLoaded', updateScrollColor);
</script>
